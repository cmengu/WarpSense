#!/bin/bash
set -e

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SCRIPTS_DIR="$REPO_ROOT/.cursor/scripts"

if [[ ! -f "$SCRIPTS_DIR/cto-workflow-auto.sh" ]]; then
    echo "❌ Error: cto-workflow-auto.sh not found in $SCRIPTS_DIR"
    exit 1
fi

show_banner() {
    clear
    echo ""
    echo "╔═══════════════════════════════════════════════════════════╗"
    echo "║                                                           ║"
    echo "║          🧠  CTO STRATEGIC TASK GENERATOR  🧠            ║"
    echo "║                                                           ║"
    echo "║        Powered by Composer 1.5 + Memory Learning         ║"
    echo "║          With Context-Aware Feedback System              ║"
    echo "║                                                           ║"
    echo "╚═══════════════════════════════════════════════════════════╝"
    echo ""
}

show_menu() {
    echo "┌───────────────────────────────────────────────────────────┐"
    echo "│                       MAIN MENU                           │"
    echo "└───────────────────────────────────────────────────────────┘"
    echo ""
    echo "  [1] 🚀 Quick Context (one line)"
    echo "  [2] ✏️  Multi-line Context (paste) - RECOMMENDED ✨"
    echo "  [3] 📁 Load Context from File"
    echo "  [4] 🔄 Use Previous Context"
    echo "  [5] 📊 View Recent Strategies"
    echo "  [6] 📈 Show Statistics"
    echo "  [7] ❌ Exit"
    echo ""
    echo "───────────────────────────────────────────────────────────"
    echo ""
}

clear_input_buffer() {
    while IFS= read -r -t 0.001 -n 1; do :; done 2>/dev/null
}

# ─────────────────────────────────────────────────────────────────
# run_goal_intake: asks the Opus-style questions before running.
# Returns GOAL_CONTEXT as a global variable.
# ─────────────────────────────────────────────────────────────────
run_goal_intake() {
    echo ""
    echo "┌───────────────────────────────────────────────────────────┐"
    echo "│               🎯 GOAL INTAKE (30 seconds)                 │"
    echo "│   Answering these makes the plan 10x more relevant.       │"
    echo "└───────────────────────────────────────────────────────────┘"
    echo ""

    # Q1: Primary goal
    echo "Q1. What is your PRIMARY goal for the next 10 days?"
    echo "    [1] Close a customer / pilot deal"
    echo "    [2] Raise a seed round"
    echo "    [3] Validate product-market fit"
    echo "    [4] Ship to production and get real data"
    echo "    [5] Something else (type it)"
    echo ""
    read -p "    Choice [1-5]: " goal_choice
    case "$goal_choice" in
        1) primary_goal="Close a customer or pilot deal" ;;
        2) primary_goal="Raise a seed round from investors" ;;
        3) primary_goal="Validate product-market fit with real users" ;;
        4) primary_goal="Ship to production and get real data" ;;
        5)
            echo ""
            read -p "    Describe your goal: " primary_goal
            ;;
        *) primary_goal="General progress — no specific goal defined" ;;
    esac

    echo ""

    # Q2: Time constraint
    echo "Q2. How many days do you have before your next hard deadline?"
    echo "    (e.g. investor meeting, demo, pilot kickoff)"
    read -p "    Days: " days_until
    [[ -z "$days_until" ]] && days_until="10"

    echo ""

    # Q3: Biggest blocker
    echo "Q3. What is the single biggest thing blocking you right now?"
    echo "    (leave blank to skip)"
    read -p "    Blocker: " biggest_blocker

    echo ""

    # Q4: What's working
    echo "Q4. What's one thing that's been working well recently?"
    echo "    (leave blank to skip)"
    read -p "    Working well: " whats_working

    echo ""

    # Build the GOAL_CONTEXT string
    GOAL_CONTEXT="PRIMARY GOAL: $primary_goal
TIME CONSTRAINT: $days_until days until next hard deadline
BIGGEST BLOCKER: ${biggest_blocker:-Not specified}
WHAT'S WORKING: ${whats_working:-Not specified}"

    echo "────────────────────────────────────────────────────────"
    echo "✅ Goal context captured:"
    echo "$GOAL_CONTEXT"
    echo "────────────────────────────────────────────────────────"
    echo ""
    read -p "Looks good? (yes to continue / no to redo): " goal_confirm
    if [[ ! "$goal_confirm" =~ ^[Yy] ]]; then
        run_goal_intake   # recurse once if they want to redo
    fi
}

# ─────────────────────────────────────────────────────────────────
# execute_cto: passes context as $1 and goal context as $2
# to workflow script. The workflow script will NOT re-prompt.
# ─────────────────────────────────────────────────────────────────
execute_cto() {
    local context="$1"

    # Run goal intake (sets $GOAL_CONTEXT globally)
    run_goal_intake

    echo ""
    echo "┌───────────────────────────────────────────────────────────┐"
    echo "│                  STARTING CTO WORKFLOW                    │"
    echo "└───────────────────────────────────────────────────────────┘"
    echo ""
    echo "📋 Context: ${context:0:60}$([ ${#context} -gt 60 ] && echo '...')"
    echo "🎯 Goal:    ${primary_goal}"
    echo "⏰ Started: $(date '+%Y-%m-%d %H:%M:%S')"
    echo ""
    echo "───────────────────────────────────────────────────────────"
    echo ""

    # Pass context as $1 and goal context as $2
    "$SCRIPTS_DIR/cto-workflow-auto.sh" "$context" "$GOAL_CONTEXT"
    local workflow_exit_code=$?

    clear_input_buffer

    echo ""

    if [[ $workflow_exit_code -eq 0 ]]; then
        echo "┌───────────────────────────────────────────────────────────┐"
        echo "│                  ✅ STRATEGY COMPLETE                     │"
        echo "└───────────────────────────────────────────────────────────┘"
    else
        echo "┌───────────────────────────────────────────────────────────┐"
        echo "│                 ⚠️  STRATEGY INTERRUPTED                  │"
        echo "└───────────────────────────────────────────────────────────┘"
    fi
    echo ""
    echo "💡 Strategy saved in: .cursor/taskspace/"
    echo ""

    echo "Returning to menu in 3 seconds (or press any key)..."
    read -t 3 -n 1 2>/dev/null || true
}

run_quick_context() {
    echo ""
    echo "┌───────────────────────────────────────────────────────────┐"
    echo "│                   QUICK CONTEXT INPUT                     │"
    echo "└───────────────────────────────────────────────────────────┘"
    echo ""
    echo "💡 Examples:"
    echo "   • Polish the investor demo — torch viz needs to be smoother"
    echo "   • Scale ingestion pipeline for 1000 concurrent sessions"
    echo "   • Add real-time angle deviation alerts"
    echo ""
    read -p "📝 Enter context: " context

    if [[ -z "$context" ]]; then
        echo ""
        echo "⚠️  Context cannot be empty"
        sleep 2
        return
    fi

    execute_cto "$context"
}

run_multiline_context() {
    echo ""
    echo "┌───────────────────────────────────────────────────────────┐"
    echo "│                MULTI-LINE CONTEXT INPUT                   │"
    echo "└───────────────────────────────────────────────────────────┘"
    echo ""
    echo "💡 Paste or type your strategic context (multiple lines OK)"
    echo "   Type END on a new line when finished, or press Ctrl+D"
    echo ""
    echo "───────────────────────────────────────────────────────────"
    echo ""

    context=""
    echo "Start typing/pasting (type END or Ctrl+D to finish):"
    echo ""

    while IFS= read -r line; do
        if [[ "$line" == "END" ]]; then
            break
        fi
        context="${context}${line}
"
    done

    if [[ -z "$context" ]]; then
        echo ""
        echo "⚠️  Context cannot be empty"
        sleep 2
        return
    fi

    echo ""
    echo "┌───────────────────────────────────────────────────────────┐"
    echo "│                    CONTEXT PREVIEW                        │"
    echo "└───────────────────────────────────────────────────────────┘"
    echo ""
    echo "$context"
    echo ""
    echo "───────────────────────────────────────────────────────────"
    echo ""

    read -p "Execute with this context? (yes/no): " confirm

    if [[ ! "$confirm" =~ ^[Yy] ]]; then
        echo ""
        echo "❌ Cancelled"
        sleep 1
        return
    fi

    execute_cto "$context"
}

load_from_file() {
    echo ""
    echo "┌───────────────────────────────────────────────────────────┐"
    echo "│                LOAD CONTEXT FROM FILE                     │"
    echo "└───────────────────────────────────────────────────────────┘"
    echo ""
    read -p "📁 Enter file path: " filepath

    if [[ -z "$filepath" ]]; then
        echo ""
        echo "⚠️  File path cannot be empty"
        sleep 2
        return
    fi

    filepath="${filepath/#\~/$HOME}"

    if [[ ! -f "$filepath" ]]; then
        echo ""
        echo "❌ Error: File not found: $filepath"
        sleep 2
        return
    fi

    context=$(cat "$filepath")

    if [[ -z "$context" ]]; then
        echo ""
        echo "⚠️  File is empty"
        sleep 2
        return
    fi

    echo ""
    echo "Preview (first 10 lines):"
    echo "$context" | head -10
    [[ $(echo "$context" | wc -l) -gt 10 ]] && echo "... (truncated)"
    echo ""

    read -p "Execute with this context? (yes/no): " confirm

    if [[ ! "$confirm" =~ ^[Yy] ]]; then
        echo ""
        echo "❌ Cancelled"
        sleep 1
        return
    fi

    execute_cto "$context"
}

use_previous_context() {
    if [[ ! -f ".cursor/memory/last-context.txt" ]]; then
        echo ""
        echo "❌ No previous context found"
        echo ""
        echo "Returning to menu in 2 seconds..."
        read -t 2 -n 1 2>/dev/null || true
        return
    fi

    context=$(cat ".cursor/memory/last-context.txt")

    echo ""
    echo "┌───────────────────────────────────────────────────────────┐"
    echo "│                  PREVIOUS CONTEXT                         │"
    echo "└───────────────────────────────────────────────────────────┘"
    echo ""
    echo "$context"
    echo ""
    echo "───────────────────────────────────────────────────────────"
    echo ""

    read -p "Use this context? (yes/no): " confirm

    if [[ ! "$confirm" =~ ^[Yy] ]]; then
        echo ""
        echo "❌ Cancelled"
        sleep 1
        return
    fi

    execute_cto "$context"
}

view_recent() {
    echo ""
    echo "┌───────────────────────────────────────────────────────────┐"
    echo "│                  RECENT STRATEGIES                        │"
    echo "└───────────────────────────────────────────────────────────┘"
    echo ""

    if [[ ! -d ".cursor/taskspace" ]]; then
        echo "📁 No strategies found yet. Run CTO workflow first!"
        echo ""
        echo "Returning to menu in 2 seconds..."
        read -t 2 -n 1 2>/dev/null || true
        return
    fi

    echo "📂 Last 5 strategies:"
    echo ""
    ls -dt .cursor/taskspace/*/ 2>/dev/null | head -5 | while IFS= read -r dir; do
        if [[ -f "$dir/tasks-final.md" ]]; then
            timestamp=$(basename "$dir")

            if [[ -f "$dir/cto.log" ]]; then
                context=$(grep "User Context:" "$dir/cto.log" | head -1 | sed 's/.*User Context: //')
                [[ ${#context} -gt 50 ]] && context="${context:0:50}..."
            else
                context="N/A"
            fi

            echo "  📁 $timestamp"
            echo "     📝 Context: $context"

            if [[ -f "$dir/priority-history.md" ]]; then
                score=$(tail -1 "$dir/priority-history.md" | grep -o '[0-9.]*' | tail -1 || echo "N/A")
                iterations=$(grep -c "Iteration" "$dir/priority-history.md" || echo "N/A")
                echo "     ✨ Score: $score/10 ($iterations iterations)"
            fi

            task_count=$(grep -c "^\./agent" "$dir/tasks-final.md" 2>/dev/null || echo "0")
            echo "     🚀 Tasks: $task_count"
            echo ""
        fi
    done

    echo "───────────────────────────────────────────────────────────"
    echo ""
    echo "Returning to menu in 3 seconds (or press any key)..."
    read -t 3 -n 1 2>/dev/null || true
}

show_stats() {
    echo ""
    echo "┌───────────────────────────────────────────────────────────┐"
    echo "│                     STATISTICS                            │"
    echo "└───────────────────────────────────────────────────────────┘"
    echo ""

    if [[ ! -d ".cursor/taskspace" ]]; then
        echo "📊 No strategies run yet"
        echo ""
        echo "Returning to menu in 2 seconds..."
        read -t 2 -n 1 2>/dev/null || true
        return
    fi

    total_runs=$(ls -d .cursor/taskspace/*/ 2>/dev/null | wc -l | tr -d ' ')
    echo "  📊 Total CTO Runs: $total_runs"
    echo ""

    if [[ $total_runs -gt 0 ]]; then
        total_score=0
        score_count=0
        for dir in .cursor/taskspace/*/; do
            if [[ -f "$dir/priority-history.md" ]]; then
                score=$(tail -1 "$dir/priority-history.md" | grep -o '[0-9.]*' | tail -1)
                if [[ -n "$score" ]]; then
                    total_score=$(echo "$total_score + $score" | bc -l 2>/dev/null || echo "$total_score")
                    score_count=$((score_count + 1))
                fi
            fi
        done

        if [[ $score_count -gt 0 ]]; then
            avg_score=$(echo "scale=1; $total_score / $score_count" | bc -l 2>/dev/null || echo "N/A")
            echo "  ✨ Average Strategy Score: $avg_score/10"
            echo ""
        fi

        if [[ -f ".cursor/memory/user-feedback.jsonl" ]]; then
            feedback_count=$(wc -l < ".cursor/memory/user-feedback.jsonl" | tr -d ' ')
            echo "  💬 Rejection Entries: $feedback_count"

            if [[ $feedback_count -gt 0 ]]; then
                echo "     Context Types:"
                for ctype in demo scale feature fix general; do
                    count=$(grep -c "\"context_type\":\"$ctype\"" ".cursor/memory/user-feedback.jsonl" 2>/dev/null || echo "0")
                    [[ $count -gt 0 ]] && echo "       • $ctype: $count"
                done
            fi
            echo ""
        fi

        if [[ -f ".cursor/memory/learnings.md" ]]; then
            learnings_count=$(grep -c "^- \[" ".cursor/memory/learnings.md" 2>/dev/null || echo "0")
            echo "  🧠 Learnings Logged: $learnings_count"
            echo ""
        fi

        latest_dir=$(ls -dt .cursor/taskspace/*/ 2>/dev/null | head -1)
        if [[ -f "$latest_dir/cto.log" ]]; then
            latest_context=$(grep "User Context:" "$latest_dir/cto.log" | head -1 | sed 's/.*User Context: //')
            [[ ${#latest_context} -gt 50 ]] && latest_context="${latest_context:0:50}..."
            echo "  🕐 Most Recent Run: \"$latest_context\""

            if [[ -f "$latest_dir/priority-history.md" ]]; then
                score=$(tail -1 "$latest_dir/priority-history.md" | grep -o '[0-9.]*' | tail -1)
                echo "     ✨ Score: $score/10"
            fi
            echo ""
        fi
    fi

    echo "───────────────────────────────────────────────────────────"
    echo ""
    echo "Returning to menu in 3 seconds (or press any key)..."
    read -t 3 -n 1 2>/dev/null || true
}

# ─────────────────────────────────────────────────────────────────
# MAIN LOOP
# ─────────────────────────────────────────────────────────────────
while true; do
    show_banner
    show_menu

    clear_input_buffer

    read -p "Choose option [1-7]: " choice

    case $choice in
        1) run_quick_context ;;
        2) run_multiline_context ;;
        3) load_from_file ;;
        4) use_previous_context ;;
        5) view_recent ;;
        6) show_stats ;;
        7)
            echo ""
            echo "┌───────────────────────────────────────────────────────────┐"
            echo "│                      GOODBYE! 👋                          │"
            echo "└───────────────────────────────────────────────────────────┘"
            echo ""
            exit 0
            ;;
        *)
            echo ""
            echo "⚠️  Invalid choice — enter 1 through 7"
            sleep 1
            ;;
    esac
done