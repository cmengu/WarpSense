# WarpSense — Environment variables for Docker deploy
# Copy to .env and customize: cp .env.example .env
# deploy.sh will auto-generate a secure DB_PASSWORD if unset or if this placeholder is used.

# Database (required for deploy.sh)
# Leave as-is or unset; deploy.sh generates a secure value. Never use in production.
DB_PASSWORD=CHANGE_ME_ON_DEPLOY

# CORS: Origins allowed for API requests (backend). For remote deploy, add your server origin.
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://YOUR_SERVER_IP:3000,http://frontend:3000

# Frontend: API URL the browser uses to reach the backend
# For same-machine: http://localhost:8000
# For remote server: http://your-server-ip:8000 or https://api.yourdomain.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# Optional: Backend
# ENVIRONMENT=production
# DEBUG=false

# Replay page: comparison session for side-by-side 3D view.
# Set to a session ID to fetch novice for comparison. Use empty string to disable.
# NEXT_PUBLIC_DEMO_COMPARISON_SESSION_ID=sess_novice_001

# Landing page CTAs (optional)
# NEXT_PUBLIC_DEMO_BOOKING_URL — Calendly/Cal.com URL for Schedule Demo; fallback: /demo
# NEXT_PUBLIC_INVESTOR_DECK_URL — PDF URL for Download Deck; fallback: #download-deck
# NEXT_PUBLIC_DEMO_BOOKING_URL=
# NEXT_PUBLIC_INVESTOR_DECK_URL=

# Optional: Custom domain / email (for reports)
# FRONTEND_URL=https://your-domain.com
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
