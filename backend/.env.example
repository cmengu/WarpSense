# Copy to .env and fill in values
# cp .env.example .env

# PostgreSQL connection (required)
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/welding_sessions

# Development: enables dev seed route (POST /api/dev/seed-mock-sessions)
ENV=development

# CORS allowed origins (comma-separated). Default: http://localhost:3000
# CORS_ORIGINS=http://localhost:3000,https://myapp.example.com
