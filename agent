#!/bin/bash
set -e

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SCRIPTS_DIR="$REPO_ROOT/.cursor/scripts"

if [[ ! -f "$SCRIPTS_DIR/agent-workflow-auto.sh" ]]; then
    echo "❌ Error: agent-workflow-auto.sh not found in $SCRIPTS_DIR"
    exit 1
fi

# ── CLI shortcut: ./agent --task "..." skips the menu entirely ───────
DIRECT_TASK=""
while [[ $# -gt 0 ]]; do
    case "$1" in
        --task|-t)
            DIRECT_TASK="$2"
            shift 2
            ;;
        *)
            # Bare positional arg also works: ./agent "Build the dashboard"
            [[ -z "$DIRECT_TASK" ]] && DIRECT_TASK="$1"
            shift
            ;;
    esac
done

if [[ -n "$DIRECT_TASK" ]]; then
    "$SCRIPTS_DIR/agent-workflow-auto.sh" "$DIRECT_TASK"
    exit $?
fi

# ── Interactive menu (no args) ────────────────────────────────────────

show_banner() {
    clear
    echo ""
    echo "╔═══════════════════════════════════════════════════════════╗"
    echo "║                                                           ║"
    echo "║        🤖  AUTONOMOUS AGENT WORKFLOW LAUNCHER  🤖        ║"
    echo "║                                                           ║"
    echo "║           Powered by Composer 1.5 + Claude               ║"
    echo "║         With Autonomous Quality Refinement               ║"
    echo "║                                                           ║"
    echo "╚═══════════════════════════════════════════════════════════╝"
    echo ""
}

show_menu() {
    echo "┌───────────────────────────────────────────────────────────┐"
    echo "│                       MAIN MENU                           │"
    echo "└───────────────────────────────────────────────────────────┘"
    echo ""
    echo "  [1] 🚀 Run New Task (Quick)"
    echo "  [2] 📝 Run Task from File"
    echo "  [3] ✏️  Run Task (Multi-line Input)"
    echo "  [4] 📁 View Recent Outputs"
    echo "  [5] 📊 Show Statistics"
    echo "  [6] ⚙️  Settings"
    echo "  [7] ❌ Exit"
    echo ""
    echo "───────────────────────────────────────────────────────────"
    echo ""
}

clear_input_buffer() {
    while IFS= read -r -t 0.001 -n 1; do :; done 2>/dev/null
}

run_quick_task() {
    echo ""
    echo "┌───────────────────────────────────────────────────────────┐"
    echo "│                   QUICK TASK INPUT                        │"
    echo "└───────────────────────────────────────────────────────────┘"
    echo ""
    echo "💡 Examples:"
    echo "   • Add session export to CSV feature"
    echo "   • Create real-time monitoring dashboard"
    echo "   • Fix authentication bug in login flow"
    echo ""
    read -p "📝 Enter task description: " task

    if [[ -z "$task" ]]; then
        echo ""
        echo "⚠️  Task cannot be empty"
        sleep 2
        return
    fi

    execute_task "$task"
}

run_task_from_file() {
    echo ""
    echo "┌───────────────────────────────────────────────────────────┐"
    echo "│                   LOAD TASK FROM FILE                     │"
    echo "└───────────────────────────────────────────────────────────┘"
    echo ""
    read -p "📁 Enter file path: " filepath

    if [[ -z "$filepath" ]]; then
        echo "⚠️  File path cannot be empty"; sleep 2; return
    fi

    filepath="${filepath/#\~/$HOME}"

    if [[ ! -f "$filepath" ]]; then
        echo "❌ Error: File not found: $filepath"; sleep 2; return
    fi

    task=$(cat "$filepath")

    if [[ -z "$task" ]]; then
        echo "⚠️  File is empty"; sleep 2; return
    fi

    echo ""
    echo "$task" | head -20
    [[ $(echo "$task" | wc -l) -gt 20 ]] && echo "... (showing first 20 lines)"
    echo ""
    read -p "Execute this task? (yes/no): " confirm
    [[ ! "$confirm" =~ ^[Yy] ]] && { echo "❌ Cancelled"; sleep 1; return; }

    execute_task "$task"
}

run_multiline_task() {
    echo ""
    echo "┌───────────────────────────────────────────────────────────┐"
    echo "│                 MULTI-LINE TASK INPUT                     │"
    echo "└───────────────────────────────────────────────────────────┘"
    echo ""
    echo "💡 Type END on a new line or Ctrl+D to finish"
    echo ""

    task=""
    while IFS= read -r line; do
        [[ "$line" == "END" ]] && break
        task="${task}${line}
"
    done

    if [[ -z "$task" ]]; then
        echo "⚠️  Task cannot be empty"; sleep 2; return
    fi

    echo ""
    echo "$task" | head -20
    [[ $(echo "$task" | wc -l) -gt 20 ]] && echo "... (showing first 20 lines)"
    echo ""
    read -p "Execute this task? (yes/no): " confirm
    [[ ! "$confirm" =~ ^[Yy] ]] && { echo "❌ Cancelled"; sleep 1; return; }

    execute_task "$task"
}

# ── Core executor — always calls agent-workflow-auto.sh ─────────────
execute_task() {
    local task="$1"

    echo ""
    echo "┌───────────────────────────────────────────────────────────┐"
    echo "│                   STARTING WORKFLOW                       │"
    echo "└───────────────────────────────────────────────────────────┘"
    echo ""
    echo "📋 Task: ${task:0:80}$([ ${#task} -gt 80 ] && echo '...')"
    echo "⏰ Started: $(date '+%Y-%m-%d %H:%M:%S')"
    echo ""
    echo "───────────────────────────────────────────────────────────"
    echo ""

    "$SCRIPTS_DIR/agent-workflow-auto.sh" "$task"
    local workflow_exit_code=$?

    clear_input_buffer

    echo ""

    if [[ $workflow_exit_code -eq 0 ]]; then
        echo "┌───────────────────────────────────────────────────────────┐"
        echo "│                   ✅ TASK COMPLETE                        │"
        echo "└───────────────────────────────────────────────────────────┘"
    else
        echo "┌───────────────────────────────────────────────────────────┐"
        echo "│                   ⚠️  TASK INTERRUPTED                    │"
        echo "└───────────────────────────────────────────────────────────┘"
    fi
    echo ""
    echo "💡 Outputs saved in: .cursor/workspaces/"
    echo ""

    echo "Returning to menu in 2 seconds (or press any key)..."
    read -t 2 -n 1 2>/dev/null || true
}

view_recent() {
    echo ""
    echo "┌───────────────────────────────────────────────────────────┐"
    echo "│                   RECENT OUTPUTS                          │"
    echo "└───────────────────────────────────────────────────────────┘"
    echo ""

    if [[ ! -d ".cursor/workspaces" ]]; then
        echo "📁 No outputs found yet. Run a task first!"
        echo ""
        echo "Returning to menu in 2 seconds..."
        read -t 2 -n 1 2>/dev/null || true
        return
    fi

    echo "📂 Last 5 tasks:"
    echo ""
    ls -dt .cursor/workspaces/*/ 2>/dev/null | head -5 | while IFS= read -r dir; do
        echo "  📁 $(basename "$dir")"
        if [[ -f "$dir/automation.log" ]]; then
            task_line=$(grep "Task:" "$dir/automation.log" | head -1 | sed 's/.*Task: //')
            [[ ${#task_line} -gt 60 ]] && task_line="${task_line:0:60}..."
            echo "     📝 $task_line"
        fi
        echo ""
    done

    echo "Returning to menu in 3 seconds (or press any key)..."
    read -t 3 -n 1 2>/dev/null || true
}

show_stats() {
    echo ""
    echo "┌───────────────────────────────────────────────────────────┐"
    echo "│                     STATISTICS                            │"
    echo "└───────────────────────────────────────────────────────────┘"
    echo ""

    if [[ ! -d ".cursor/workspaces" ]]; then
        echo "📊 No tasks run yet"
        echo "Returning to menu in 2 seconds..."
        read -t 2 -n 1 2>/dev/null || true
        return
    fi

    total=$(ls -d .cursor/workspaces/*/ 2>/dev/null | wc -l | tr -d ' ')
    echo "  📊 Total Tasks Run: $total"
    echo ""
    echo "  📁 Workspace: $(pwd)/.cursor/workspaces/"
    echo "  📚 Learnings: $(pwd)/.cursor/learning_log.md"
    echo ""

    echo "Returning to menu in 3 seconds (or press any key)..."
    read -t 3 -n 1 2>/dev/null || true
}

show_settings() {
    echo ""
    echo "┌───────────────────────────────────────────────────────────┐"
    echo "│                      SETTINGS                             │"
    echo "└───────────────────────────────────────────────────────────┘"
    echo ""

    config_file=".cursor/agent-config.sh"
    [[ -f "$config_file" ]] && source "$config_file"

    AI_MODEL="${AI_MODEL:-Composer 1.5}"
    MAX_PLAN_ITERATIONS="${MAX_PLAN_ITERATIONS:-5}"
    TARGET_SCORE="${TARGET_SCORE:-9.0}"

    echo "  🤖 Model:              $AI_MODEL"
    echo "  🔢 Max Iterations:     $MAX_PLAN_ITERATIONS"
    echo "  🎯 Target Score:       $TARGET_SCORE/10"
    echo ""
    echo "  Edit .cursor/agent-config.sh to change these."
    echo ""

    echo "Returning to menu in 3 seconds (or press any key)..."
    read -t 3 -n 1 2>/dev/null || true
}

# ── Main loop ─────────────────────────────────────────────────────────
while true; do
    show_banner
    show_menu

    clear_input_buffer

    read -p "Choose option [1-7]: " choice

    case $choice in
        1) run_quick_task ;;
        2) run_task_from_file ;;
        3) run_multiline_task ;;
        4) view_recent ;;
        5) show_stats ;;
        6) show_settings ;;
        7)
            echo ""
            echo "┌───────────────────────────────────────────────────────────┐"
            echo "│                      GOODBYE! 👋                          │"
            echo "└───────────────────────────────────────────────────────────┘"
            echo ""
            exit 0
            ;;
        *)
            echo "⚠️  Invalid choice — enter 1 through 7"
            sleep 1
            ;;
    esac
done