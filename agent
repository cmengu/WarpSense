#!/bin/bash
set -e

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SCRIPTS_DIR="$REPO_ROOT/.cursor/scripts"

if [[ ! -f "$SCRIPTS_DIR/agent-workflow-auto.sh" ]]; then
    echo "Error: Scripts not found"
    exit 1
fi

show_menu() {
    clear
    echo "========================================="
    echo "   AGENT WORKFLOW LAUNCHER"
    echo "========================================="
    echo ""
    echo "1) Run single task"
    echo "2) Run multiple tasks in parallel"
    echo "3) Exit"
    echo ""
}

run_single() {
    echo ""
    read -p "Enter task: " task
    if [[ -z "$task" ]]; then
        echo "Task cannot be empty"
        return
    fi
    "$SCRIPTS_DIR/agent-workflow-auto.sh" "$task"
    read -p "Press ENTER to continue..."
}

run_multiple() {
    echo ""
    echo "Enter tasks (one per line, empty line when done):"
    tasks=()
    task_num=1
    while true; do
        read -p "Task $task_num: " task
        if [[ -z "$task" ]]; then
            break
        fi
        tasks+=("$task")
        task_num=$((task_num + 1))
    done
    
    if [[ ${#tasks[@]} -eq 0 ]]; then
        echo "No tasks entered"
        read -p "Press ENTER to continue..."
        return
    fi
    
    echo ""
    echo "Starting ${#tasks[@]} tasks in parallel..."
    "$SCRIPTS_DIR/run-parallel-tasks.sh" "${tasks[@]}"
    read -p "Press ENTER to continue..."
}

while true; do
    show_menu
    read -p "Choose [1-3]: " choice
    case $choice in
        1) run_single ;;
        2) run_multiple ;;
        3) echo "Goodbye!"; exit 0 ;;
        *) echo "Invalid choice"; sleep 1 ;;
    esac
done
